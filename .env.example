# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# NextAuth
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="https://yourdomain.vercel.app"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Email (SMTP)
SMTP_HOST="mail.privateemail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# Resend (optional - alternative to SMTP)
RESEND_API_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="https://yourdomain.vercel.app"
NEXT_PUBLIC_SITE_NAME="OLUS-BIS Immigration Services"
NEXT_PUBLIC_WHATSAPP_NUMBER="+1234567890"
NEXT_PUBLIC_PHONE_NUMBER="+1234567890"
NEXT_PUBLIC_EMAIL="info@olus-bis.com"

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="documents"
